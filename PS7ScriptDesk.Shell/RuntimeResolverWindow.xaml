<Window x:Class="PS7ScriptDesk.Shell.RuntimeResolverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PowerShell 7 Required"
        Width="620"
        Height="600"
        MinWidth="620"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        ShowInTaskbar="False"
        Background="#F8FBFF"
        Foreground="#172033"
        FontFamily="Segoe UI Variable Display, Segoe UI">
    <Window.Resources>
        <SolidColorBrush x:Key="ResolverBackgroundBrush" Color="#F8FBFF" />
        <SolidColorBrush x:Key="ResolverSurfaceBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ResolverSurfaceAltBrush" Color="#EEF4FB" />
        <SolidColorBrush x:Key="ResolverPrimaryTextBrush" Color="#172033" />
        <SolidColorBrush x:Key="ResolverSecondaryTextBrush" Color="#4B6078" />
        <SolidColorBrush x:Key="ResolverBorderBrush" Color="#C8D5E5" />
        <SolidColorBrush x:Key="ResolverButtonBrush" Color="#1F2937" />
        <SolidColorBrush x:Key="ResolverButtonHoverBrush" Color="#334155" />
        <SolidColorBrush x:Key="ResolverButtonTextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ResolverInputBrush" Color="#FFFFFF" />

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource ResolverPrimaryTextBrush}" />
        </Style>

        <Style TargetType="{x:Type Run}">
            <Setter Property="Foreground" Value="{StaticResource ResolverPrimaryTextBrush}" />
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="{StaticResource ResolverInputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ResolverPrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ResolverBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{StaticResource ResolverPrimaryTextBrush}" />
        </Style>

        <Style TargetType="{x:Type Expander}">
            <Setter Property="Foreground" Value="{StaticResource ResolverPrimaryTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource ResolverButtonBrush}" />
            <Setter Property="Foreground" Value="{StaticResource ResolverButtonTextBrush}" />
            <Setter Property="BorderBrush" Value="#475569" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource ResolverButtonHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#111827" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22" Background="{StaticResource ResolverBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="PS7 ScriptDesk requires PowerShell 7.0 or newer."
                   FontSize="20"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap" />

        <Border Grid.Row="1"
                Margin="0,14,0,0"
                Padding="14"
                Background="{StaticResource ResolverSurfaceBrush}"
                BorderBrush="{StaticResource ResolverBorderBrush}"
                BorderThickness="1"
                CornerRadius="10">
            <TextBlock TextWrapping="Wrap" LineHeight="20">
                PowerShell 7 was not found automatically. Windows PowerShell 5.1 is not supported for this version of PS7 ScriptDesk.
                <LineBreak />
                <LineBreak />
                Click <Run FontWeight="SemiBold">Try Automatic Search Again</Run>, browse directly to <Run FontFamily="Consolas">pwsh.exe</Run>, or install PowerShell 7 from Microsoft and restart the app.
                <LineBreak />
                <LineBreak />
                Common install location: <Run FontFamily="Consolas">C:\Program Files\PowerShell\7\pwsh.exe</Run>
                <LineBreak />
                Microsoft Store alias location: <Run FontFamily="Consolas">%LOCALAPPDATA%\Microsoft\WindowsApps\pwsh.exe</Run>
            </TextBlock>
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="0,16,0,6"
                   Text="Selected runtime path"
                   FontWeight="SemiBold" />

        <DockPanel Grid.Row="3"
                   LastChildFill="True">
            <Button Content="Browse..."
                    Width="104"
                    Margin="10,0,0,0"
                    Click="BrowseButton_Click"
                    DockPanel.Dock="Right" />
            <TextBox x:Name="SelectedPathTextBox"
                     IsReadOnly="True"
                     Padding="8,5"
                     VerticalContentAlignment="Center" />
        </DockPanel>

        <ScrollViewer Grid.Row="4"
                      Margin="0,16,0,0"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border BorderBrush="{StaticResource ResolverBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Background="{StaticResource ResolverSurfaceBrush}">
                    <StackPanel>
                        <TextBlock Text="Status"
                                   FontWeight="SemiBold" />
                        <TextBlock x:Name="StatusMessageTextBlock"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   LineHeight="20" />
                    </StackPanel>
                </Border>

                <Expander Header="More Info"
                          Margin="0,14,0,0"
                          IsExpanded="True">
                    <Border Margin="0,8,0,0"
                            Padding="12"
                            Background="{StaticResource ResolverSurfaceAltBrush}"
                            BorderBrush="{StaticResource ResolverBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock Margin="0,0,0,8" TextWrapping="Wrap" Foreground="{StaticResource ResolverSecondaryTextBrush}">
                                PS7 ScriptDesk requires PowerShell 7.x or newer. Windows PowerShell 5.1 is a different product and is not supported for normal startup.
                            </TextBlock>
                            <TextBlock Margin="0,0,0,8" TextWrapping="Wrap" Foreground="{StaticResource ResolverSecondaryTextBrush}">
                                Look for <Run FontFamily="Consolas">pwsh.exe</Run>, not <Run FontFamily="Consolas">powershell.exe</Run>.
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource ResolverSecondaryTextBrush}">
                                If this window appears even though PowerShell 7 is installed, click <Run FontWeight="SemiBold">Open Logs Folder</Run> and include the startup/runtime logs in your support report.
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <UniformGrid Grid.Row="5"
                     Rows="3"
                     Columns="2"
                     Margin="0,18,0,0">
            <Button Content="Try Automatic Search Again"
                    Margin="0,0,7,7"
                    Click="RetryDiscoveryButton_Click" />
            <Button Content="Browse for pwsh.exe"
                    Margin="7,0,0,7"
                    IsDefault="True"
                    Click="BrowseButton_Click" />
            <Button Content="Open Logs Folder"
                    Margin="0,7,7,7"
                    Click="OpenLogsFolderButton_Click" />
            <Button Content="Copy Logs Path"
                    Margin="7,7,0,7"
                    Click="CopyLogsPathButton_Click" />
            <Button Content="Exit"
                    Margin="0,7,7,0"
                    IsCancel="True"
                    Click="ExitButton_Click" />
            <Button Content="Copy Setup Help Text"
                    Margin="7,7,0,0"
                    Click="CopyHelpTextButton_Click" />
        </UniformGrid>
    </Grid>
</Window>
