<UserControl x:Class="PS7ScriptDesk.Shell.Controls.TerminalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf">
    <Grid>
        <wv2:WebView2 x:Name="WebView"
                      Focusable="True" />
        <!-- Shown only when WebView2 Runtime is missing -->
        <Border x:Name="FallbackBanner"
                Visibility="Collapsed"
                Background="#1e1e1e"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Padding="24,16"
                CornerRadius="6">
            <StackPanel>
                <TextBlock Text="WebView2 Runtime is required for the integrated terminal."
                           Foreground="#cccccc"
                           FontFamily="Consolas"
                           FontSize="13"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Install it from: https://developer.microsoft.com/en-us/microsoft-edge/webview2/"
                           Foreground="#4ec9b0"
                           FontFamily="Consolas"
                           FontSize="12"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
