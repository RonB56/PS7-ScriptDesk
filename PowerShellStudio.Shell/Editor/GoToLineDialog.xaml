<Window x:Class="PowerShellStudio.Shell.Editor.GoToLineDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:help="clr-namespace:PowerShellStudio.Shell.Help"
        Title="Go to Line"
        Width="320"
        Height="130"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown"
        help:ContextHelp.Key="GoToLine.Dialog">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10" help:ContextHelp.Key="GoToLine.Dialog">
            <TextBlock Text="Line number" VerticalAlignment="Center" Margin="0,0,10,0" help:ContextHelp.Key="GoToLine.LineNumber" />
            <TextBlock x:Name="RangeHintText"
                       Foreground="DimGray"
                       FontSize="11"
                       VerticalAlignment="Center"
                       help:ContextHelp.Key="GoToLine.LineNumber" />
        </StackPanel>

        <TextBox x:Name="LineNumberBox"
                 Grid.Row="1"
                 Margin="0,0,0,12"
                 Padding="6,4"
                 KeyDown="LineNumberBox_KeyDown"
                 TextChanged="LineNumberBox_TextChanged"
                 help:ContextHelp.Key="GoToLine.LineNumber" />

        <UniformGrid Grid.Row="2" Rows="1" Columns="2">
            <Button x:Name="OkButton"
                    Content="Go"
                    IsDefault="True"
                    Padding="10,4"
                    Margin="0,0,6,0"
                    Click="OkButton_Click"
                    IsEnabled="False"
                    help:ContextHelp.Key="GoToLine.Go" />
            <Button Content="Cancel"
                    IsCancel="True"
                    Padding="10,4"
                    Margin="6,0,0,0"
                    Click="CancelButton_Click"
                    help:ContextHelp.Key="GoToLine.Dialog" />
        </UniformGrid>
    </Grid>
</Window>
