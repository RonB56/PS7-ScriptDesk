<Window x:Class="PowerShellStudio.Shell.Help.ContextHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PowerShellStudio Help"
        Height="700"
        Width="860"
        MinHeight="500"
        MinWidth="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource Theme.App.Background}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                Margin="0,0,0,12"
                Style="{StaticResource PanelCardBorderStyle}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Left" Margin="0,0,16,0">
                    <TextBlock x:Name="TopicTitleText"
                               FontSize="{StaticResource Theme.FontSize.Heading}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource Theme.Text.Primary}"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="TopicQuickSummaryText"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource Theme.Text.Secondary}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Border DockPanel.Dock="Right"
                        VerticalAlignment="Top"
                        Padding="12,6"
                        Background="{DynamicResource Theme.Accent.Primary}"
                        CornerRadius="{StaticResource Radius.Pill}">
                    <TextBlock Text="Context Help"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource Theme.Accent.Foreground}" />
                </Border>
            </DockPanel>
        </Border>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel x:Name="BodyPanel" />
        </ScrollViewer>

        <DockPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="FooterText"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource Theme.Text.Secondary}"
                       TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                <Button x:Name="RelatedTopicsButton"
                        Content="Related Topics"
                        MinWidth="120"
                        Margin="0,0,8,0"
                        Padding="12,6"
                        Click="RelatedTopicsButton_Click" />
                <Button Content="Close"
                        IsDefault="True"
                        MinWidth="90"
                        Padding="12,6"
                        Click="CloseButton_Click" />
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
