<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Theme.Shadow.Color">#001B44</Color>

    <SolidColorBrush x:Key="Theme.App.Background" Color="#00163F"/>
    <SolidColorBrush x:Key="Theme.Surface.Primary" Color="#04255A"/>
    <SolidColorBrush x:Key="Theme.Surface.Secondary" Color="#03204D"/>
    <SolidColorBrush x:Key="Theme.Surface.Tertiary" Color="#0A2F6A"/>
    <SolidColorBrush x:Key="Theme.Surface.Hover" Color="#15407D"/>
    <SolidColorBrush x:Key="Theme.Surface.Pressed" Color="#072652"/>

    <SolidColorBrush x:Key="Theme.Border.Subtle" Color="#25558D"/>
    <SolidColorBrush x:Key="Theme.Border.Strong" Color="#3F6EA5"/>

    <SolidColorBrush x:Key="Theme.Text.Primary" Color="#F1F6FF"/>
    <SolidColorBrush x:Key="Theme.Text.Secondary" Color="#A4C0E4"/>
    <SolidColorBrush x:Key="Theme.Text.Inverse" Color="#00163F"/>

    <SolidColorBrush x:Key="Theme.Accent.Primary" Color="#38BDF8"/>
    <SolidColorBrush x:Key="Theme.Accent.Hover" Color="#7DD3FC"/>
    <SolidColorBrush x:Key="Theme.Accent.Pressed" Color="#0EA5E9"/>
    <SolidColorBrush x:Key="Theme.Accent.Foreground" Color="#00163F"/>

    <SolidColorBrush x:Key="Theme.Control.Background" Color="#0A2F6A"/>
    <SolidColorBrush x:Key="Theme.Control.Border" Color="#3F6EA5"/>
    <SolidColorBrush x:Key="Theme.Control.Foreground" Color="#F1F6FF"/>
    <SolidColorBrush x:Key="Theme.Control.HoverBackground" Color="#15407D"/>
    <SolidColorBrush x:Key="Theme.Control.PressedBackground" Color="#082550"/>

    <SolidColorBrush x:Key="Theme.Input.Background" Color="#001B44"/>
    <SolidColorBrush x:Key="Theme.Input.Foreground" Color="#F1F6FF"/>
    <SolidColorBrush x:Key="Theme.Input.Border" Color="#315A88"/>
    <SolidColorBrush x:Key="Theme.Input.FocusBorder" Color="#38BDF8"/>

    <SolidColorBrush x:Key="Theme.Menu.Background" Color="#03204D"/>
    <SolidColorBrush x:Key="Theme.Menu.Foreground" Color="#F1F6FF"/>

    <SolidColorBrush x:Key="Theme.Selection.Background" Color="#0F4C81"/>

    <SolidColorBrush x:Key="Theme.Status.Warning.Background" Color="#3C2A00"/>
    <SolidColorBrush x:Key="Theme.Status.Warning.Border" Color="#FFD166"/>
    <SolidColorBrush x:Key="Theme.Status.Warning.Foreground" Color="#FFE9A3"/>
    <SolidColorBrush x:Key="Theme.Status.Error.Background" Color="#4B1020"/>
    <SolidColorBrush x:Key="Theme.Status.Error.Border" Color="#FB7185"/>
    <SolidColorBrush x:Key="Theme.Status.Error.Foreground" Color="#FFD4DC"/>
    <SolidColorBrush x:Key="Theme.Status.Info.Foreground" Color="#7DD3FC"/>

    <SolidColorBrush x:Key="Theme.ScrollBar.Track" Color="#001B44"/>
    <SolidColorBrush x:Key="Theme.ScrollBar.Thumb" Color="#3F6EA5"/>
    <SolidColorBrush x:Key="Theme.ScrollBar.ThumbHover" Color="#5D8BC0"/>

    <SolidColorBrush x:Key="Theme.Icon.Accent" Color="#2F74C0"/>
    <SolidColorBrush x:Key="Theme.Icon.Primary" Color="#38BDF8"/>
    <SolidColorBrush x:Key="Theme.Icon.Muted" Color="#A4C0E4"/>
    <SolidColorBrush x:Key="Theme.Icon.Success" Color="#22C55E"/>
    <SolidColorBrush x:Key="Theme.Icon.Warning" Color="#FBBF24"/>
    <SolidColorBrush x:Key="Theme.Icon.Danger" Color="#FB7185"/>

    <!-- Existing keys retained for the rest of the shell/editor -->
    <SolidColorBrush x:Key="Theme.Editor.Background" Color="#012456"/>
    <SolidColorBrush x:Key="Theme.Editor.Foreground" Color="#EEEDF0"/>
    <SolidColorBrush x:Key="Theme.Editor.SelectionBackground" Color="#0F4C81"/>
    <SolidColorBrush x:Key="Theme.Editor.CurrentLineBackground" Color="#0A2F6A"/>
    <SolidColorBrush x:Key="Theme.Editor.LineHighlight" Color="#0A2F6A"/>
    <SolidColorBrush x:Key="Theme.Editor.LineNumber" Color="#7FA0C0"/>

    <SolidColorBrush x:Key="Theme.Console.Background" Color="#012456"/>
    <SolidColorBrush x:Key="Theme.Console.Foreground" Color="#EEEDF0"/>

    <SolidColorBrush x:Key="Theme.Panel.Background" Color="#00143C"/>
    <SolidColorBrush x:Key="Theme.Panel.Border" Color="#1A3F70"/>
    <SolidColorBrush x:Key="Theme.Panel.Foreground" Color="#EEEDF0"/>
    <SolidColorBrush x:Key="Theme.Panel.DimForeground" Color="#7FA0C0"/>

    <SolidColorBrush x:Key="Theme.Syntax.Keyword" Color="#38BDF8"/>
    <SolidColorBrush x:Key="Theme.Syntax.String" Color="#FB923C"/>
    <SolidColorBrush x:Key="Theme.Syntax.Comment" Color="#4ADE80"/>
    <SolidColorBrush x:Key="Theme.Syntax.Variable" Color="#F9A8D4"/>
    <SolidColorBrush x:Key="Theme.Syntax.Cmdlet" Color="#FDE047"/>
    <SolidColorBrush x:Key="Theme.Syntax.Type" Color="#67E8F9"/>
    <SolidColorBrush x:Key="Theme.Syntax.Number" Color="#BEF264"/>
    <SolidColorBrush x:Key="Theme.Syntax.Parameter" Color="#C4B5FD"/>

</ResourceDictionary>
