<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="Theme.Shadow.Color">#000000</Color>

    <SolidColorBrush x:Key="Theme.App.Background" Color="#111827"/>
    <SolidColorBrush x:Key="Theme.Surface.Primary" Color="#1F2937"/>
    <SolidColorBrush x:Key="Theme.Surface.Secondary" Color="#18212F"/>
    <SolidColorBrush x:Key="Theme.Surface.Tertiary" Color="#273449"/>
    <SolidColorBrush x:Key="Theme.Surface.Hover" Color="#314159"/>
    <SolidColorBrush x:Key="Theme.Surface.Pressed" Color="#172131"/>

    <SolidColorBrush x:Key="Theme.Border.Subtle" Color="#334155"/>
    <SolidColorBrush x:Key="Theme.Border.Strong" Color="#475569"/>

    <SolidColorBrush x:Key="Theme.Text.Primary" Color="#E5EEF9"/>
    <SolidColorBrush x:Key="Theme.Text.Secondary" Color="#9FB2C9"/>
    <SolidColorBrush x:Key="Theme.Text.Inverse" Color="#0F172A"/>

    <SolidColorBrush x:Key="Theme.Accent.Primary" Color="#60A5FA"/>
    <SolidColorBrush x:Key="Theme.Accent.Hover" Color="#93C5FD"/>
    <SolidColorBrush x:Key="Theme.Accent.Pressed" Color="#3B82F6"/>
    <SolidColorBrush x:Key="Theme.Accent.Foreground" Color="#F8FBFF"/>

    <SolidColorBrush x:Key="Theme.Control.Background" Color="#243244"/>
    <SolidColorBrush x:Key="Theme.Control.Border" Color="#41566F"/>
    <SolidColorBrush x:Key="Theme.Control.Foreground" Color="#E5EEF9"/>
    <SolidColorBrush x:Key="Theme.Control.HoverBackground" Color="#2F435A"/>
    <SolidColorBrush x:Key="Theme.Control.PressedBackground" Color="#203043"/>

    <SolidColorBrush x:Key="Theme.Input.Background" Color="#0F172A"/>
    <SolidColorBrush x:Key="Theme.Input.Foreground" Color="#E5EEF9"/>
    <SolidColorBrush x:Key="Theme.Input.Border" Color="#334155"/>
    <SolidColorBrush x:Key="Theme.Input.FocusBorder" Color="#60A5FA"/>

    <SolidColorBrush x:Key="Theme.Menu.Background" Color="#1B2432"/>
    <SolidColorBrush x:Key="Theme.Menu.Foreground" Color="#E5EEF9"/>

    <SolidColorBrush x:Key="Theme.Selection.Background" Color="#1D4ED8"/>

    <SolidColorBrush x:Key="Theme.Status.Warning.Background" Color="#3B2B13"/>
    <SolidColorBrush x:Key="Theme.Status.Warning.Border" Color="#D4A550"/>
    <SolidColorBrush x:Key="Theme.Status.Warning.Foreground" Color="#FFE5A8"/>
    <SolidColorBrush x:Key="Theme.Status.Error.Background" Color="#3A1719"/>
    <SolidColorBrush x:Key="Theme.Status.Error.Border" Color="#EF4444"/>
    <SolidColorBrush x:Key="Theme.Status.Error.Foreground" Color="#FECACA"/>
    <SolidColorBrush x:Key="Theme.Status.Info.Foreground" Color="#93C5FD"/>

    <SolidColorBrush x:Key="Theme.ScrollBar.Track" Color="#111827"/>
    <SolidColorBrush x:Key="Theme.ScrollBar.Thumb" Color="#475569"/>
    <SolidColorBrush x:Key="Theme.ScrollBar.ThumbHover" Color="#64748B"/>

    <SolidColorBrush x:Key="Theme.Icon.Accent" Color="#60A5FA"/>
    <SolidColorBrush x:Key="Theme.Icon.Primary" Color="#93C5FD"/>
    <SolidColorBrush x:Key="Theme.Icon.Muted" Color="#94A3B8"/>
    <SolidColorBrush x:Key="Theme.Icon.Success" Color="#34D399"/>
    <SolidColorBrush x:Key="Theme.Icon.Warning" Color="#FBBF24"/>
    <SolidColorBrush x:Key="Theme.Icon.Danger" Color="#F87171"/>

    <!-- Existing keys retained for the rest of the shell/editor -->
    <SolidColorBrush x:Key="Theme.Editor.Background" Color="#0F172A"/>
    <SolidColorBrush x:Key="Theme.Editor.Foreground" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="Theme.Editor.SelectionBackground" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="Theme.Editor.CurrentLineBackground" Color="#172131"/>
    <SolidColorBrush x:Key="Theme.Editor.LineHighlight" Color="#172131"/>
    <SolidColorBrush x:Key="Theme.Editor.LineNumber" Color="#64748B"/>

    <SolidColorBrush x:Key="Theme.Console.Background" Color="#020617"/>
    <SolidColorBrush x:Key="Theme.Console.Foreground" Color="#E2E8F0"/>

    <SolidColorBrush x:Key="Theme.Panel.Background" Color="#1F2937"/>
    <SolidColorBrush x:Key="Theme.Panel.Border" Color="#475569"/>
    <SolidColorBrush x:Key="Theme.Panel.Foreground" Color="#E5EEF9"/>
    <SolidColorBrush x:Key="Theme.Panel.DimForeground" Color="#94A3B8"/>

    <SolidColorBrush x:Key="Theme.Syntax.Keyword" Color="#60A5FA"/>
    <SolidColorBrush x:Key="Theme.Syntax.String" Color="#F59E0B"/>
    <SolidColorBrush x:Key="Theme.Syntax.Comment" Color="#34D399"/>
    <SolidColorBrush x:Key="Theme.Syntax.Variable" Color="#93C5FD"/>
    <SolidColorBrush x:Key="Theme.Syntax.Cmdlet" Color="#FDE68A"/>
    <SolidColorBrush x:Key="Theme.Syntax.Type" Color="#5EEAD4"/>
    <SolidColorBrush x:Key="Theme.Syntax.Number" Color="#86EFAC"/>
    <SolidColorBrush x:Key="Theme.Syntax.Parameter" Color="#C4B5FD"/>

</ResourceDictionary>
