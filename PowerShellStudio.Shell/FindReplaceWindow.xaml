<Window x:Class="PowerShellStudio.Shell.FindReplaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:help="clr-namespace:PowerShellStudio.Shell.Help"
        Title="Find / Replace"
        Width="460"
        Height="285"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        PreviewKeyDown="Window_PreviewKeyDown"
        help:ContextHelp.Key="FindReplace.Dialog">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" Text="Find:" help:ContextHelp.Key="FindReplace.FindText" />
        <TextBox x:Name="FindTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10" MinWidth="280" help:ContextHelp.Key="FindReplace.FindText" />

        <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,10" VerticalAlignment="Center" Text="Replace:" help:ContextHelp.Key="FindReplace.ReplaceText" />
        <TextBox x:Name="ReplaceTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10" MinWidth="280" help:ContextHelp.Key="FindReplace.ReplaceText" />

        <!-- Options row -->
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,14">
            <CheckBox x:Name="MatchCaseCheckBox"
                      Margin="0,0,16,0"
                      VerticalAlignment="Center"
                      Content="Match _case"
                      help:ContextHelp.Key="FindReplace.MatchCase" />
            <CheckBox x:Name="WholeWordCheckBox"
                      Margin="0,0,16,0"
                      VerticalAlignment="Center"
                      Content="_Whole word"
                      ToolTip="Match only complete words"
                      help:ContextHelp.Key="FindReplace.WholeWord" />
            <CheckBox x:Name="UseRegexCheckBox"
                      VerticalAlignment="Center"
                      Content="Use _regex"
                      ToolTip="Treat the search pattern as a .NET regular expression"
                      help:ContextHelp.Key="FindReplace.Regex" />
        </StackPanel>

        <!-- Status text -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="3" Grid.Column="1"
                   Margin="0,0,0,10"
                   Foreground="Red"
                   FontSize="11"
                   Text=""
                   TextWrapping="NoWrap"
                   help:ContextHelp.Key="FindReplace.Dialog" />

        <UniformGrid Grid.Row="4" Grid.ColumnSpan="2" Rows="1" Columns="5" Margin="0,2,0,0">
            <Button Content="Find _Next (F3)"  Margin="0,0,8,0" Padding="8,4" Click="FindNext_Click"   help:ContextHelp.Key="FindReplace.FindNext" />
            <Button Content="Find _Prev"       Margin="0,0,8,0" Padding="8,4" Click="FindPrev_Click"   ToolTip="Find Previous (Shift+F3)" help:ContextHelp.Key="FindReplace.FindNext" />
            <Button Content="_Replace"         Margin="0,0,8,0" Padding="8,4" Click="Replace_Click"    help:ContextHelp.Key="FindReplace.ReplaceOne" />
            <Button Content="Replace _All"     Margin="0,0,8,0" Padding="8,4" Click="ReplaceAll_Click" help:ContextHelp.Key="FindReplace.ReplaceAll" />
            <Button Content="Close"            Padding="8,4"   Click="Close_Click"                     help:ContextHelp.Key="FindReplace.Dialog" />
        </UniformGrid>
    </Grid>
</Window>
