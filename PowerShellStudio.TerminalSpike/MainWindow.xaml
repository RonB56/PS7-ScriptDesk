<Window x:Class="PowerShellStudio.TerminalSpike.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PowerShellStudio.TerminalSpike"
        Title="PS7 ScriptDesk Terminal Spike"
        Height="760"
        Width="1200"
        MinHeight="500"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Background="#0F1115"
        Foreground="#E6EDF3">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="12"
                Background="#161B22"
                BorderBrush="#30363D"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <UniformGrid Grid.Row="0"
                             Columns="3"
                             Rows="2">
                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="WebView2"
                                   FontWeight="SemiBold"
                                   Foreground="#8B949E" />
                        <TextBlock Text="{Binding WebView2Status}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="xterm"
                                   FontWeight="SemiBold"
                                   Foreground="#8B949E" />
                        <TextBlock Text="{Binding XtermStatus}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,8">
                        <TextBlock Text="ConPTY"
                                   FontWeight="SemiBold"
                                   Foreground="#8B949E" />
                        <TextBlock Text="{Binding ConPtyStatus}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="PowerShell"
                                   FontWeight="SemiBold"
                                   Foreground="#8B949E" />
                        <TextBlock Text="{Binding PowerShellStatus}" TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Input Bytes"
                                   FontWeight="SemiBold"
                                   Foreground="#8B949E" />
                        <TextBlock Text="{Binding InputByteCount}" />
                    </StackPanel>
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Output Bytes"
                                   FontWeight="SemiBold"
                                   Foreground="#8B949E" />
                        <TextBlock Text="{Binding OutputByteCount}" />
                    </StackPanel>
                </UniformGrid>

                <StackPanel Grid.Row="1"
                            Margin="0,12,0,0">
                    <TextBlock Text="Last Error"
                               FontWeight="SemiBold"
                               Foreground="#8B949E" />
                    <TextBlock Text="{Binding LastError}"
                               TextWrapping="Wrap"
                               MinHeight="20" />
                </StackPanel>

                <DockPanel Grid.Row="2"
                           Margin="0,12,0,0"
                           LastChildFill="True">
                    <Button Content="Open Log Folder"
                            Width="130"
                            Height="28"
                            Margin="0,0,8,0"
                            Click="OpenLogFolder_Click" />
                    <Button Content="Open Log File"
                            Width="120"
                            Height="28"
                            Margin="0,0,12,0"
                            Click="OpenLogFile_Click" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="#8B949E"
                               Text="{Binding LogPath}"
                               TextWrapping="Wrap" />
                </DockPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#0D1117"
                BorderBrush="#30363D"
                BorderThickness="1"
                CornerRadius="8"
                SnapsToDevicePixels="True">
            <local:TerminalHost x:Name="TerminalHostControl" />
        </Border>
    </Grid>
</Window>
